{
  "cleanUrls": true,
  "trailingSlash": false,
  "rewrites": [
    {
      "source": "/",
      "destination": "/frontend/cosmic-portfolio.html"
    },
    {
      "source": "/assets/:path*",
      "destination": "/frontend/assets/:path*"
    },
    {
      "source": "/:file(index.css|animations.css|cosmic.css|index.js|animations.js|cosmic-universe.js|avatar.png)",
      "destination": "/frontend/:file"
    }
  ]
}
