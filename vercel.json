{
  "cleanUrls": true,
  "trailingSlash": false,
  "rewrites": [
    {
      "source": "/",
      "destination": "/frontend/index.html"
    },
    {
      "source": "/assets/:path*",
      "destination": "/frontend/assets/:path*"
    },
    {
      "source": "/:file(cosmic.css|lucide-local.js|animations.js|cosmic-universe.js|avatar.png)",
      "destination": "/frontend/:file"
    }
  ]
}
